@page "/"

<PageTitle>GigSonar</PageTitle>

<div class="container-fluid bg-dark text-light py-5">
    <div class="container">
        <div class="row align-items-center min-vh-75">

            <!-- Left side: Hero content -->
            <div class="col-lg-6 mb-5 mb-lg-0">

                <span class="badge bg-primary mb-3">
                    Discover live music near you
                </span>

                <h1 class="display-4 fw-bold mb-3">
                    Find events, venues and artists around you
                </h1>

                <p class="lead text-light-emphasis mb-4">
                    Search for your favorite artists, discover local venues,
                    and explore nearby music events on the map.
                </p>

                <!-- Search card -->
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-4">

                        <label class="form-label text-dark fw-semibold">
                            What are you looking for?
                        </label>

                        <div class="input-group mb-3">
                            <input class="form-control form-control-lg"
                                   placeholder="Search events, venues or artists..." />

                            <button class="btn btn-primary btn-lg"
                                    type="button">
                                Search
                            </button>
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Events
                            </button>

                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Venues
                            </button>

                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Artists
                            </button>
                        </div>

                    </div>
                </div>

            </div>

            <!-- Right side: Map preview -->
            <div class="col-lg-6">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                    <div class="card-header bg-white border-0 p-4">
                        <div class="d-flex justify-content-between align-items-center gap-3">

                            <div>
                                <h5 class="mb-1 text-dark">
                                    Nearby events
                                </h5>

                                <small class="text-muted">
                                    Google Maps integration will be added later
                                </small>
                            </div>

                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Use my location
                            </button>

                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="bg-light d-flex align-items-center justify-content-center text-center"
                             style="height: 420px;">

                            <div class="px-4">
                                <div class="display-6 mb-3">
                                    🗺️
                                </div>

                                <h5 class="text-dark mb-2">
                                    Google Maps area
                                </h5>

                                <p class="text-muted mb-0">
                                    Later this will show the user's current location
                                    and nearby event pins.
                                </p>
                            </div>

                        </div>
                    </div>

                </div>

                <!-- Future feature cards -->
                <div class="row mt-4 g-3">

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold">
                                    Event search
                                </h6>

                                <p class="card-text text-muted small mb-0">
                                    Search local events from your database or external API.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold">
                                    Venue search
                                </h6>

                                <p class="card-text text-muted small mb-0">
                                    Find venues and later show them on the map.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body">
                                <h6 class="card-title fw-semibold">
                                    Artist search
                                </h6>

                                <p class="card-text text-muted small mb-0">
                                    Search artists and later display related events.
                                </p>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>