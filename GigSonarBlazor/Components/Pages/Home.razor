@page "/"
@inject IConfiguration Configuration

<PageTitle>Gig Sonar</PageTitle>

<div class="container-fluid bg-light-subtle text-light py-5">
    <div class="container">
        <div class="row align-items-center min-vh-75">

            <!-- Left side: Hero content -->
            <div class="col-lg-6 mb-5 mb-lg-0">

                <span class="badge bg-primary mb-3">
                    Discover live music near you
                </span>

                <h1 class="display-4 fw-bold mb-3 text-dark">
                    Find events, venues and artists around you
                </h1>

                <p class="lead text-light-emphasis mb-4">
                    Search for your favorite artists, discover local venues,
                    and explore nearby music events on the map.
                </p>

                <!-- Search card -->
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-4">

                        <label class="form-label text-dark fw-semibold">
                            What are you looking for?
                        </label>

                        <div class="input-group mb-3">
                            <input class="form-control form-control-lg"
                                   placeholder="Search events, venues or artists..." />

                            <button class="btn btn-primary btn-lg"
                                    type="button">
                                Search
                            </button>
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Events
                            </button>

                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Venues
                            </button>

                            <button class="btn btn-outline-primary btn-sm"
                                    type="button">
                                Artists
                            </button>
                        </div>

                    </div>
                </div>

            </div>

            <!-- Right side: Map preview -->
            <div class="col-lg-6">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                    <div class="card-header bg-white border-0 p-4">
                        <div class="d-flex justify-content-between align-items-center gap-3">

                            <div>
                                <h5 class="mb-1 text-dark">
                                    Nearby events
                                </h5>
                                @*
                                <small class="text-muted">
                                    Google Maps integration will be added later
                                </small>
                            </div>
*@
                                <button class="btn btn-outline-primary btn-sm"
                                        type="button">
                                    Use my location
                                </button>

                            </div>
                        </div>

                        <div class="card-body p-0">
                            <div class="bg-light d-flex align-items-center justify-content-center text-center"
                                 style="height: 420px;">
                                @*
                            <div class="px-4">
                                <div class="display-6 mb-3">
                                    🗺️
                                </div>

                                <h5 class="text-dark mb-2">
                                    Google Maps area
                                </h5>

                                <p class="text-muted mb-0">
                                    Later this will show the user's current location
                                    and nearby event pins.
                                </p>
                                *@
                            </div>
                            <GoogleMap ApiKey="@GoogleMapsApiKey"
                                       Center="@MapCenter"
                                       Height="420"
                                       Width="100"
                                       WidthUnit="Unit.Percentage"
                                       Zoom="12"
                                       Markers="@MapMarkers" />
                        </div>
                    </div>
                    
                </div>
                
            </div>

        </div>
    </div>
</div>

@code {
    private string GoogleMapsApiKey = string.Empty;

    protected override void OnInitialized()
    {
        GoogleMapsApiKey = Configuration["ApiKeys:GoogleMaps"] ?? string.Empty;
    }

    private GoogleMapCenter MapCenter = new(48.2082, 16.3738); // Vienna

    private IEnumerable<GoogleMapMarker> MapMarkers = new List<GoogleMapMarker>
    {
        @*
        new GoogleMapMarker(48.2082, 16.3738)
        {
            Title = "Vienna city center"
        },

        new GoogleMapMarker(48.1976, 16.3597)
        {
            Title = "Example event near Karlsplatz"
        },

        new GoogleMapMarker(48.2197, 16.3950)
        {
            Title = "Example event near Prater"
        }
        *@
    };
}